# OpenRouter — required.
OPENROUTER_API_KEY=sk-or-...

# Model id. Browse the full list at https://openrouter.ai/models
MODEL=anthropic/claude-sonnet-4.5

# MCP server (Streamable HTTP). Default is localhost:8081/mcp.
MCP_URL=http://localhost:8081/mcp

# --- Optional: OAuth 2.0 client_credentials for the MCP server ---
# Provide ALL THREE to enable. If any is unset, requests go out without
# an Authorization header.
# AUTH_TOKEN_ENDPOINT=https://auth.example.com/oauth/token
# AUTH_CLIENT_ID=your-client-id
# AUTH_CLIENT_SECRET=your-client-secret

# --- Optional ---
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_PROVIDER_ORDER=anthropic     # pin upstream provider
# SYSTEM_PROMPT="You are a helpful assistant."
# MCP_CHAT_LOG_DIR=logs
